# Copy this file to secrets.toml and fill in your values.
# For Streamlit Cloud: paste these into the Secrets section in app settings.

# ─── Claude API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# ─── Dev bypass (skip OAuth during local development) ───────────────────────
# Set this to your email to sign in without Google SSO. Remove when going
# live with real auth.
# dev_user_email = "you@example.com"

# ─── Team auth (Google Workspace SSO) ───────────────────────────────────────
# Domain-restrict sign-in. Value may be a single domain or a list.
allowed_domain = "yourdomain.com"

# Streamlit native OIDC block. Requires streamlit >= 1.42.
# Create an OAuth 2.0 client ID in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Register the redirect_uri there — it MUST match exactly (per environment).
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "generate-a-long-random-string-and-keep-it-secret"
client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ─── Notion integration (optional) ──────────────────────────────────────────
# Omit NOTION_ENABLED or set it to anything other than "true" to disable the
# poller entirely — Streamlit + CLI + filesystem continue working unchanged.
#
# Setup steps:
# 1. https://www.notion.so/my-integrations → New integration → get the secret
# 2. Share the parent Notion page with the integration (Share → invite it)
# 3. python -m integrations.bootstrap_notion --parent-page-id <page_id>
# 4. Paste the two DB ids below

# NOTION_ENABLED        = "true"
# NOTION_TOKEN          = "secret_..."
# NOTION_DEALS_DB_ID    = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# NOTION_OUTPUTS_DB_ID  = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# NOTION_BOT_USER_EMAIL = "notion-bot@yourdomain.com"  # fallback when the
#                                                     # triggering user's
#                                                     # email can't be resolved

# ─── Slack notifications (optional) ─────────────────────────────────────────
# Incoming-webhook URL posted to on agent completion / failure.
# https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL = "https://hooks.slack.com/services/..."
